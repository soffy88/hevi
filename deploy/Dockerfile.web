# hevi-web — Next.js 16 / React 19 production image
# Build-time: NEXT_PUBLIC_API_BASE is baked into the JS bundle
# Usage (from deploy/docker-compose-cftunnel.yml):
#   context: ../hevi-web
#   dockerfile: ../deploy/Dockerfile.web

FROM node:22-slim AS deps
WORKDIR /app
COPY package.json package-lock.json ./
COPY vendor/ ./vendor/
RUN npm ci --prefer-offline

FROM node:22-slim AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .
ARG NEXT_PUBLIC_API_BASE=https://hevi.kanpan.co
ARG NEXT_PUBLIC_USE_MOCK=false
ENV NEXT_PUBLIC_API_BASE=$NEXT_PUBLIC_API_BASE
ENV NEXT_PUBLIC_USE_MOCK=$NEXT_PUBLIC_USE_MOCK
RUN npm run build

FROM node:22-slim AS runner
WORKDIR /app
ENV NODE_ENV=production
COPY --from=builder /app/.next ./.next
COPY --from=builder /app/public ./public
COPY --from=builder /app/node_modules ./node_modules
COPY --from=builder /app/package.json ./package.json
EXPOSE 3000
HEALTHCHECK --interval=15s --timeout=5s --retries=3 CMD curl -sf http://localhost:3000 || exit 1
CMD ["npm", "start"]
