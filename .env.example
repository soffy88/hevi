# hevi v6 — 环境变量模板
# 使用方法: cp .env.example .env 然后按注释填写各项
# 阶段说明: F1=最小闭环(LTX-2), F2=扩展(Wan/VoiceBox), F3=上线(Auth/支付)

# ─────────────────────────────────────────────────────────────────────────────
# === F1 必需 (真跑 E2E 最小资源集) ==========================================
# ─────────────────────────────────────────────────────────────────────────────

# fal.ai API Key — LTX-2 视频生成
# 提供方: Wiki/fal.ai 控制台 → API Keys
# 计费: 按秒收费,见 FAL_PRICE_PER_SECOND
FAL_API_KEY=

# fal.ai 单价(美元/秒),用于成本熔断(P10.E3)估算
# 提供方: fal.ai 定价页面,Wiki 校准后填入
FAL_PRICE_PER_SECOND=0.04

# PostgreSQL 连接串
# dev 本地: postgresql://hevi:hevi@localhost:5432/hevi
# prod Docker: postgresql://hevi:${POSTGRES_PASSWORD}@postgres:5432/hevi
DATABASE_URL=postgresql://hevi:hevi@localhost:5432/hevi

# PostgreSQL 密码 (prod docker-compose 用)
POSTGRES_PASSWORD=hevi

# MinIO 对象存储 — 视频/图像产物存储
# dev 本地: localhost:9000
# prod Docker: minio:9000 (内部网络)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=hevi-assets

# ─────────────────────────────────────────────────────────────────────────────
# === F2 扩展 (Wan 视频 / VoiceBox TTS / Duix Avatar) =======================
# ─────────────────────────────────────────────────────────────────────────────

# Alibaba DashScope — Wan 视频生成 (wan2.1-i2v-turbo)
# 提供方: 阿里云控制台 → DashScope → API Key
DASHSCOPE_API_KEY=

# Wan 单价(美元/秒)
DASHSCOPE_PRICE_PER_SECOND=0.05

# VoiceBox TTS — 本地 1.5B 权重
# 提供方: Wiki 提供权重下载链接
# 填写本地权重目录绝对路径,例如: /opt/models/vibevoice-1.5b
VIBEVOICE_MODEL_PATH=

# Duix Digital Avatar — Docker 服务地址
# 部署文档: docs/E2E_SETUP.md#duix
# 示例: http://localhost:8088
DUIX_SERVICE_URL=

# ─────────────────────────────────────────────────────────────────────────────
# === F3 上线 (OAuth / 支付 / 域名) ==========================================
# ─────────────────────────────────────────────────────────────────────────────

# Google OAuth 2.0 — 用户登录
# 提供方: Google Cloud Console → API & Services → Credentials
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# JWT 签名密钥 — 生成: openssl rand -hex 32
JWT_SECRET=

# Paddle 支付 — 订阅扣费
# 提供方: Paddle 控制台 → Developer Tools → API Keys
PADDLE_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# === 通用配置 ================================================================
# ─────────────────────────────────────────────────────────────────────────────

# 成本熔断上限(美元/任务) — P10.E3 circuit breaker
# 超过此金额的任务将被拒绝执行
COST_LIMIT_PER_TASK_USD=50

# 日志级别: debug / info / warning / error
LOG_LEVEL=info

# 允许的 CORS 来源(逗号分隔),生产环境收紧
# 示例: https://hevi.example.com,https://app.hevi.io
CORS_ORIGINS=*
