# hevi v6 — 环境变量模板
# 使用方法: cp .env.example .env 然后按注释填写各项
# 阶段说明: F1=最小闭环(LTX-2), F2=扩展(Wan/VoiceBox), F3=上线(Auth/支付)

# ─────────────────────────────────────────────────────────────────────────────
# === F1 必需 (真跑 E2E 最小资源集) ==========================================
# ─────────────────────────────────────────────────────────────────────────────

# fal.ai API Key — LTX-2 视频生成
FAL_API_KEY=

# fal.ai LTX-2 计费 tier: fast (默认) | pro
LTX2_DEFAULT_TIER=fast

# PostgreSQL 连接串
DATABASE_URL=postgresql://hevi:hevi@localhost:5432/hevi

# PostgreSQL 密码
POSTGRES_PASSWORD=hevi

# MinIO 对象存储
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio12345
MINIO_BUCKET=hevi-assets

# ─────────────────────────────────────────────────────────────────────────────
# === F2 扩展 (Wan 视频 / VoiceBox TTS / Duix Avatar) =======================
# ─────────────────────────────────────────────────────────────────────────────

# Alibaba DashScope — Wan 视频生成 (wan2.1-i2v-turbo)
# 提供方: 阿里云控制台 → DashScope → API Key
DASHSCOPE_API_KEY=

# Wan 单价(美元/秒)
DASHSCOPE_PRICE_PER_SECOND=0.05

# Vidu API — HEVI-EXEC-01 视频生成主通道 (Reference-to-Video)
# 提供方: Vidu 官网控制台 → API Key
VIDU_API_KEY=

# VoiceBox TTS — 本地 1.5B 权重
# 提供方: Wiki 提供权重下载链接
# 填写本地权重目录绝对路径,例如: /opt/models/vibevoice-1.5b
VIBEVOICE_MODEL_PATH=

# Duix Digital Avatar — Docker 服务地址
# 部署文档: docs/E2E_SETUP.md#duix
# 示例: http://localhost:8088
DUIX_SERVICE_URL=

# ─────────────────────────────────────────────────────────────────────────────
# === F3 上线 (OAuth / 支付 / 域名) ==========================================
# ─────────────────────────────────────────────────────────────────────────────

# Google OAuth 2.0 — 用户登录
# 提供方: Google Cloud Console → API & Services → Credentials
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# JWT 签名密钥 — 生成: openssl rand -hex 32
JWT_SECRET=

# Paddle 支付 — 订阅扣费
# 提供方: Paddle 控制台 → Developer Tools → API Keys
PADDLE_API_KEY=

# ─────────────────────────────────────────────────────────────────────────────
# === 通用配置 ================================================================
# ─────────────────────────────────────────────────────────────────────────────

# 成本熔断上限(美元/任务) — P10.E3 circuit breaker
# 超过此金额的任务将被拒绝执行
COST_LIMIT_PER_TASK_USD=50

# JWT 密钥 — 必填,生成: openssl rand -hex 32 (留空则服务启动即退出)
JWT_SECRET=

# Paddle 支付 (SaaS-4)
# PADDLE_WEBHOOK_SECRET 留空时 webhook 验签 fail-closed(拒绝所有 webhook)
PADDLE_API_KEY=
PADDLE_WEBHOOK_SECRET=
PADDLE_ENVIRONMENT=sandbox

# 日志级别: debug / info / warning / error
LOG_LEVEL=info

# 允许的 CORS 来源(逗号分隔),生产环境必须收紧为具体域名。
# 注意: 设为 * 时浏览器禁止携带凭证,后端会自动关闭 allow_credentials。
# 本地开发示例: http://localhost:3000  生产示例: https://app.hevi.io
CORS_ORIGINS=http://localhost:3000
